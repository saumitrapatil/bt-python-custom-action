# Python bytecode and tool caches — produced when contributors run the
# action scripts (ruff, mypy, pytest) locally.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage / test reports emitted by python-coverage-action
.coverage
coverage.xml
junit.xml

# Build artifacts emitted by python-build-action
build/
dist/
*.egg-info/

# Trivy SARIF reports emitted by the trivy-* actions
*.sarif

# NOTE: the self-test fixture dir (_fixture/) is intentionally NOT ignored —
# test-actions.yml scaffolds and lints it, and ruff/black skip gitignored
# paths. A local self-test run leaves an untracked _fixture/; delete it after.

# Python virtual environments
.venv/
venv/

# Local environment files — never commit secrets
.env

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
